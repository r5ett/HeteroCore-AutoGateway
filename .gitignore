# ==========================================
# C/C++ & 嵌入式通用编译产物
# ==========================================
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst
*.axf
*.out
*.su
*.iex
*.htm
*.lnp
*.dep
*.crf

# ==========================================
# Keil MDK-ARM 专属过滤
# (保留 .uvprojx 工程文件，过滤本地用户配置和编译输出)
# ==========================================
*.uvguix.*
*.uvoptx
*/MDK-ARM/DebugConfig/
*/MDK-ARM/RTE/
*/MDK-ARM/Listings/
*/MDK-ARM/Objects/
# 如果有同名的无后缀编译文件夹，也将其过滤
*/MDK-ARM/*/

# ==========================================
# STM32CubeMX 生成的临时文件
# ==========================================
*.bak
*.tmp
*.log

# ==========================================
# CMake & Makefiles (用于未来 IMX6ULL 的 Linux C++ 开发)
# ==========================================
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# ==========================================
# 操作系统与编辑器生成的临时文件
# ==========================================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.history/
*.code-workspace